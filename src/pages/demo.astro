          <div class="flex items-center gap-1 mb-6">
            <i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i><i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i><i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i><i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i><i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i>
          </div>
          <p class="text-primary/80 italic mb-8 leading-relaxed">"Finally found a salon that understands high-end color. Simply perfect."</p>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-accent/10 flex items-center justify-center text-[10px] font-bold text-accent">I</div>
            <span class="text-xs uppercase tracking-widest font-bold">Isabella Rossi</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Menu -->
  <section id="services" class="py-24 md:py-40 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-20 space-y-4">
        <span class="text-accent text-xs uppercase tracking-[0.3em] font-semibold">The Menu</span>
        <h2 class="text-4xl md:text-6xl font-serif">Boutique Services</h2>
      </div>
      
      <div class="space-y-12">
        <div class="group flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-primary/10 pb-8 hover:border-accent transition-colors duration-500">
          <div class="space-y-2">
            <h3 class="text-2xl font-serif group-hover:text-accent transition-colors">Signature Cut & Style</h3>
            <p class="text-primary/60 text-sm max-w-md">Precision cutting tailored to your face shape and hair texture.</p>
          </div>
          <span class="text-accent font-serif text-xl md:text-2xl">from $120</span>
        </div>
        <div class="group flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-primary/10 pb-8 hover:border-accent transition-colors duration-500">
          <div class="space-y-2">
            <h3 class="text-2xl font-serif group-hover:text-accent transition-colors">Bespoke Balayage</h3>
            <p class="text-primary/60 text-sm max-w-md">Hand-painted highlights for a natural, sun-kissed transformation.</p>
          </div>
          <span class="text-accent font-serif text-xl md:text-2xl">from $280</span>
        </div>
