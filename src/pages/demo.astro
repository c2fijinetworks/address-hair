          <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
            <i data-lucide="instagram" class="text-bg w-8 h-8 opacity-0 group-hover:opacity-100 transition-all duration-500 scale-50 group-hover:scale-100"></i>
          </div>
        </div>
        <div class="group relative aspect-square overflow-hidden cursor-pointer transition-transform hover:-translate-y-2 duration-300">
          <img src="https://images.unsplash.com/photo-1562322140-8baeececf3df?auto=format&fit=crop&q=80&w=600&h=600" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"/>
          <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
            <i data-lucide="instagram" class="text-bg w-8 h-8 opacity-0 group-hover:opacity-100 transition-all duration-500 scale-50 group-hover:scale-100"></i>
          </div>
        </div>
        <div class="group relative aspect-square overflow-hidden cursor-pointer transition-transform hover:-translate-y-2 duration-300">
          <img src="https://images.unsplash.com/photo-1595152772835-219674b2a8a6?auto=format&fit=crop&q=80&w=600&h=600" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"/>
          <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
            <i data-lucide="instagram" class="text-bg w-8 h-8 opacity-0 group-hover:opacity-100 transition-all duration-500 scale-50 group-hover:scale-100"></i>
          </div>
        </div>
        <div class="group relative aspect-square overflow-hidden cursor-pointer transition-transform hover:-translate-y-2 duration-300">
          <img src="https://images.unsplash.com/photo-1522337660859-02fbefca4702?auto=format&fit=crop&q=80&w=600&h=600" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"/>
          <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
            <i data-lucide="instagram" class="text-bg w-8 h-8 opacity-0 group-hover:opacity-100 transition-all duration-500 scale-50 group-hover:scale-100"></i>
          </div>
        </div>
        <div class="group relative aspect-square overflow-hidden cursor-pointer transition-transform hover:-translate-y-2 duration-300">
          <img src="https://images.unsplash.com/photo-1580128660010-fdcb89269ce3?auto=format&fit=crop&q=80&w=600&h=600" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"/>
          <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
            <i data-lucide="instagram" class="text-bg w-8 h-8 opacity-0 group-hover:opacity-100 transition-all duration-500 scale-50 group-hover:scale-100"></i>
          </div>
        </div>
        <div class="group relative aspect-square overflow-hidden cursor-pointer transition-transform hover:-translate-y-2 duration-300">
          <img src="https://images.unsplash.com/photo-1521590832167-7bcbfaa6381f?auto=format&fit=crop&q=80&w=600&h=600" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"/>
          <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
            <i data-lucide="instagram" class="text-bg w-8 h-8 opacity-0 group-hover:opacity-100 transition-all duration-500 scale-50 group-hover:scale-100"></i>
          </div>
        </div>
      </div>
      
      <div class="mt-16 text-center">
        <p class="text-bg/40 text-[10px] uppercase tracking-[0.4em]">Powered by Address.Hair Live Feed Engine</p>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-24 md:py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 space-y-4">
        <span class="text-accent text-xs uppercase tracking-[0.3em] font-semibold">The Visionaries</span>
        <h2 class="text-4xl md:text-6xl font-serif">Master Stylists</h2>
      </div>
      
      <div class="grid md:grid-cols-3 gap-12">
        <div class="group cursor-pointer">
          <div class="aspect-[4/5] overflow-hidden mb-6 relative">
            <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&q=80&w=400&h=500" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 border-[1px] border-accent/0 group-hover:border-accent/30 transition-all duration-500 m-4"></div>
          </div>
          <h3 class="text-2xl font-serif mb-1">Julian Vance</h3>
          <p class="text-accent text-xs uppercase tracking-widest font-medium">Creative Director</p>
        </div>
        <div class="group cursor-pointer">
          <div class="aspect-[4/5] overflow-hidden mb-6 relative">
            <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=400&h=500" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 border-[1px] border-accent/0 group-hover:border-accent/30 transition-all duration-500 m-4"></div>
          </div>
          <h3 class="text-2xl font-serif mb-1">Amara Saint</h3>
          <p class="text-accent text-xs uppercase tracking-widest font-medium">Master Colorist</p>
        </div>
        <div class="group cursor-pointer">
          <div class="aspect-[4/5] overflow-hidden mb-6 relative">
            <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?auto=format&fit=crop&q=80&w=400&h=500" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 border-[1px] border-accent/0 group-hover:border-accent/30 transition-all duration-500 m-4"></div>
          </div>
          <h3 class="text-2xl font-serif mb-1">Leo D'Amico</h3>
          <p class="text-accent text-xs uppercase tracking-widest font-medium">Style Specialist</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Review Engine (Google Feed Demo) - Replaced Gstatic URL with reliable Wikimedia URL -->
  <section id="reviews" class="bg-bg py-24 md:py-32 border-y border-primary/5">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-center mb-16 gap-6">
        <div class="flex items-center gap-4">
          <div class="bg-white p-3 shadow-sm border border-primary/5">
            <img src="https://upload.wikimedia.org/wikipedia/commons/2/2f/Google_2015_logo.svg" alt="Google" class="h-6" />
          </div>
          <div>
            <div class="flex items-center gap-1 mb-1">
              <i data-lucide="star" class="w-3 h-3 fill-accent text-accent"></i>
              <i data-lucide="star" class="w-3 h-3 fill-accent text-accent"></i>
              <i data-lucide="star" class="w-3 h-3 fill-accent text-accent"></i>
              <i data-lucide="star" class="w-3 h-3 fill-accent text-accent"></i>
              <i data-lucide="star" class="w-3 h-3 fill-accent text-accent"></i>
            </div>
