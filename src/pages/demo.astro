          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-accent/10 flex items-center justify-center text-[10px] font-bold text-accent">E</div>
            <span class="text-xs uppercase tracking-widest font-bold">Elena Rodriguez</span>
          </div>
        </div>
        <div class="min-w-[300px] md:min-w-[400px] bg-white p-10 border border-primary/5 snap-start shadow-sm hover:shadow-md transition-shadow">
          <div class="flex items-center gap-1 mb-6">
            <i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i><i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i><i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i><i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i><i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i>
          </div>
          <p class="text-primary/80 italic mb-8 leading-relaxed">"Lumière Studio transformed my look. The stylists are true artists."</p>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-accent/10 flex items-center justify-center text-[10px] font-bold text-accent">J</div>
            <span class="text-xs uppercase tracking-widest font-bold">James Wilson</span>
          </div>
        </div>
        <div class="min-w-[300px] md:min-w-[400px] bg-white p-10 border border-primary/5 snap-start shadow-sm hover:shadow-md transition-shadow">
          <div class="flex items-center gap-1 mb-6">
            <i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i><i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i><i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i><i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i><i data-lucide="star" class="w-4 h-4 fill-accent text-accent"></i>
