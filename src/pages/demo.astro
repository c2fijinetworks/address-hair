---
// Standalone Demo Page
// Bypasses the main layout to preserve exact custom Tailwind/CSS provided
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lumière Studio - Luxury Salon Demo | Address.Hair</title>
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">

  <!-- Tailwind CSS v4 via Browser Script -->
  <script is:inline src="https://unpkg.com/@tailwindcss/browser@4"></script>

  <!-- Lucide Icons -->
  <script is:inline src="https://unpkg.com/lucide@latest"></script>

  <style type="text/tailwindcss" is:inline>
    @theme {
      --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
      --font-serif: "Playfair Display", serif;
      
      --color-primary: #1a1a1a;
      --color-accent: #C5A059;
      --color-bg: #FAF9F6;
    }

    @layer base {
      body {
        @apply bg-bg text-primary font-sans antialiased selection:bg-accent/30;
      }
      h1, h2, h3, h4, h5, h6 {
        @apply font-serif;
      }
    }
  </style>

  <style is:inline>
    /* Custom scrollbar for horizontal reviews */
    .hide-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .hide-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    /* Animations replacing Framer Motion */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .animate-fade-up-1 { animation: fadeInUp 0.8s ease-out 0.2s both; }
    .animate-fade-up-2 { animation: fadeInUp 0.8s ease-out 0.4s both; }
    .animate-fade-up-3 { animation: fadeInUp 0.8s ease-out 0.8s both; }
    
    @keyframes slideInUp {
      from { opacity: 0; transform: translateY(100px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-up { animation: slideInUp 1s cubic-bezier(0.16, 1, 0.3, 1) 2s both; }

    /* Mobile Menu Transitions */
    #mobile-menu {
      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease;
      transform: translateX(100%);
      opacity: 0;
      pointer-events: none;
    }
    #mobile-menu.open {
      transform: translateX(0);
      opacity: 1;
      pointer-events: auto;
    }
  </style>
</head>
<body>

  <!-- Navigation (Starts with text-bg to be visible over the dark hero image) -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent py-8 text-bg">
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
      <div class="flex items-center gap-2">
        <span class="text-2xl font-serif tracking-widest uppercase font-medium">Lumière</span>
        <span class="text-[10px] tracking-[0.3em] uppercase opacity-60 mt-1">Studio</span>
      </div>
      
      <div class="hidden md:flex items-center gap-12 text-xs uppercase tracking-[0.2em] font-medium">
        <a href="#about" class="hover:text-accent transition-colors">About</a>
        <a href="#services" class="hover:text-accent transition-colors">Services</a>
        <a href="#gallery" class="hover:text-accent transition-colors">Gallery</a>
        <a href="#reviews" class="hover:text-accent transition-colors">Reviews</a>
        <button id="nav-btn" class="bg-bg text-primary px-8 py-3 hover:bg-accent hover:text-bg transition-all duration-300">Book Now</button>
      </div>

      <button id="menu-btn" class="md:hidden cursor-pointer text-inherit">
        <i data-lucide="menu" class="w-6 h-6"></i>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed inset-0 z-[60] bg-bg text-primary flex flex-col p-8">
    <div class="flex justify-end">
      <button id="close-menu-btn" class="cursor-pointer">
        <i data-lucide="x" class="w-8 h-8"></i>
      </button>
    </div>
    <div class="flex flex-col gap-8 mt-12 text-2xl font-serif">
      <a href="#about" class="mobile-link">About</a>
      <a href="#services" class="mobile-link">Services</a>
      <a href="#gallery" class="mobile-link">Gallery</a>
      <a href="#reviews" class="mobile-link">Reviews</a>
      <button class="bg-primary text-bg py-4 mt-4">Book Now</button>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1560066984-138dadb4c035?auto=format&fit=crop&q=80&w=1920" 
        alt="Luxury Salon Interior" 
        class="w-full h-full object-cover scale-105 transition-transform duration-[20s] ease-linear hover:scale-110"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    
    <div class="relative z-10 text-center text-bg px-6 max-w-4xl">
      <span class="animate-fade-up-1 text-xs uppercase tracking-[0.5em] mb-6 block font-medium">
        Est. 2024 — Beverly Hills
      </span>
      <h1 class="animate-fade-up-2 text-5xl md:text-8xl font-serif mb-8 leading-[1.1]">
        Your Transformation <br /> <span class="italic">Begins Here.</span>
      </h1>
      <div class="animate-fade-up-3 flex flex-col md:flex-row items-center justify-center gap-6">
        <button class="bg-accent text-bg px-10 py-4 text-xs uppercase tracking-widest hover:bg-bg hover:text-primary transition-all duration-500 w-full md:w-auto cursor-pointer">
          Explore Services
        </button>
        <button class="border border-bg/30 backdrop-blur-sm text-bg px-10 py-4 text-xs uppercase tracking-widest hover:bg-bg/10 transition-all duration-500 w-full md:w-auto cursor-pointer">
          Meet The Team
        </button>
      </div>
    </div>

    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-bounce opacity-50 text-bg">
      <div class="w-[1px] h-12 bg-bg"></div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-24 md:py-40 px-6">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <div class="aspect-[4/5] overflow-hidden">
          <img 
            src="https://images.unsplash.com/photo-1521590832167-7bcbfaa6381f?auto=format&fit=crop&q=80&w=800" 
            alt="Stylist at work" 
            class="w-full h-full object-cover"
          />
        </div>
        <div class="absolute -bottom-8 -right-8 w-64 h-80 hidden md:block border-8 border-bg z-10">
           <img 
            src="https://images.unsplash.com/photo-1562322140-8baeececf3df?auto=format&fit=crop&q=80&w=400" 
            alt="Detail" 
            class="w-full h-full object-cover"
          />
        </div>
      </div>
      <div class="space-y-8">
