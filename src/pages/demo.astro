              <span class="text-xs font-bold uppercase tracking-widest">Verified Google Business</span>
              <i data-lucide="check-circle-2" class="w-3 h-3 text-blue-500"></i>
            </div>
          </div>
        </div>
        <div class="text-center md:text-right">
          <span class="text-4xl font-serif">4.9</span>
          <span class="text-xs uppercase tracking-widest opacity-60 ml-2">Average Rating (120+ Reviews)</span>
        </div>
