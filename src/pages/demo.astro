  <!-- JavaScript functionality -->
  <script is:inline>
    // Initialize Lucide Icons
    lucide.createIcons();

    // Scroll effect for Navbar (Fixes invisible text issue)
    const navbar = document.getElementById('navbar');
    const navBtn = document.getElementById('nav-btn');
    
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        // Scrolled state: White background, Dark text
        navbar.classList.replace('bg-transparent', 'bg-bg/95');
        navbar.classList.replace('py-8', 'py-4');
        navbar.classList.add('backdrop-blur-md', 'shadow-sm');
        
        navbar.classList.replace('text-bg', 'text-primary');
        
        navBtn.classList.replace('bg-bg', 'bg-primary');
        navBtn.classList.replace('text-primary', 'text-bg');
      } else {
        // Top state: Transparent background, Light text
        navbar.classList.replace('bg-bg/95', 'bg-transparent');
        navbar.classList.replace('py-4', 'py-8');
        navbar.classList.remove('backdrop-blur-md', 'shadow-sm');
        
        navbar.classList.replace('text-primary', 'text-bg');
        
        navBtn.classList.replace('bg-primary', 'bg-bg');
        navBtn.classList.replace('text-bg', 'text-primary');
      }
    });

    // Mobile Menu Toggle
    const menuBtn = document.getElementById('menu-btn');
    const closeBtn = document.getElementById('close-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    const toggleMenu = () => mobileMenu.classList.toggle('open');

    menuBtn.addEventListener('click', toggleMenu);
    closeBtn.addEventListener('click', toggleMenu);
    mobileLinks.forEach(link => link.addEventListener('click', toggleMenu));
  </script>
