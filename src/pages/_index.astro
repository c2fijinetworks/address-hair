---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import { headerData } from '~/navigation';
import FAQs from '~/components/widgets/FAQs.astro';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = {
  title: 'The Five-Star Secret to a Full Book | Schedule Hair | $99 Forever',
  description: 'The seamless review engine built for busy stylists. Automatically gather five-star love on Google, protect your studio’s reputation, and fill your books on autopilot. No monthly fees—just one price for a lifetime of word-of-mouth.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header {...headerData} isSticky />
  </Fragment>
  
  <Hero2
    tagline="The #1 Review Engine for Stylists & Salons"
    title='<span class="text-accent dark:text-white">Get More 5-Star Reviews While You Style.</span>'
    subtitle="We build your automated review engine, design your QR codes, and sync your best reviews to your site. Capture the 'post-haircut glow' and turn it into your best marketing ever!."
    actions={[
      { variant: 'primary', text: 'Claim My Lifetime Deal Today', href: '/pricing/' },
      /* UPDATED: Pointed Hero button to howitworks anchor */
      { text: 'See How It Works', href: '#howitworks' },
    ]}
    video="/images/hero-animation.mp4" 
    poster="/images/hero-poster.webp" 
    image={{ width: 1024, height: 576 }}
    testimonial={{
        quote: "This is a game-changer! My books are full and my Google rating shot up in weeks. It pays for itself in one haircut.",
        name: "Sarah L., Salon Owner"
    }}
  />
  
  <Features
    class="-mt-16"
    id="features"
    title="Everything You Need to Dominate Local Search"
    subtitle="We handle the tech. You focus on the hair. Here is how we help you grow your salon:"
    columns={2}
    items={[
        { title: 'The "After-Glow" Capture', description: 'Catch clients when they feel most beautiful—right at the chair. Our 3-click QR system makes it effortless for them to rave about you.', icon: 'tabler:armchair' },
        { title: 'Negative Review Shield', description: 'Unhappy client? Our system catches private feedback first, allowing you to fix the issue before a 1-star rating hits your public Google page.', icon: 'tabler:shield-check' },
        { title: 'Done-For-You Setup', description: 'Hate tech? We do the heavy lifting. We configure your Google sync, design your codes, and help you install the widget. You just print.', icon: 'tabler:settings-automation' },
        { title: 'No Monthly "SaaS Tax"', description: 'Stop paying $150/month for reputation software. One payment of $99 secures your system for the life of your business.', icon: 'tabler:pig-money' },
    ]}
  />

<Content
    class="-mt-16"
    items={[
        { title: 'Rank Higher on Google Maps', description: 'Google prioritizes salons with frequent, fresh reviews. We help you jump to the top of the "Salons Near Me" list.', icon: 'tabler:map-pin' },
        { title: 'Showcase Your Artistry', description: 'Automatically sync your best 5-star Google reviews into a beautiful wall of love on your website to build instant trust.', icon: 'tabler:user-check' },
        { title: 'Beat the Competition', description: 'When new clients compare shops, the one with 100+ reviews always wins. We make sure that shop is yours.', icon: 'tabler:trending-up' },
        { title: 'Voice Search Priority', description: 'Be the first name Siri and Alexa speak when someone says, "Find me the best hair colorist in town."', icon: 'tabler:microphone' },
    ]}
    image={{ src: '/images/testimonial-2.webp', alt: 'Stylist working on a client' }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        <span class="text-accent dark:text-white">Why Google Reviews are Your Best Sales Team</span>
      </h3>
    </Fragment>
    <Fragment slot="bg"><div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div></Fragment>
  </Content>

  <!-- FIXED JUMP LINK: Using explicit wrapper for howitworks -->
  <div id="howitworks" class="scroll-mt-20">
    <Steps2
      title="From Setup to 5-Stars in 24 Hours"
      subtitle="Three simple steps to automate your salon's reputation."
      items={[
        {
          title: 'Step 1: Secure Your License',
          description: 'Purchase your $99 lifetime deal. No hidden fees or recurring subscriptions.',
          icon: 'tabler:number-1',
        },
        {
          title: 'Step 2: We Build Your Engine',
          description: 'Tell us your salon name. We set up your profile, Google sync, and custom QR codes.',
          icon: 'tabler:number-2',
        },
        {
          title: 'Step 3: Watch the Reviews Roll In',
          description: 'Print your QR code for your stations. Clients scan, review, and your rating climbs.',
          icon: 'tabler:number-3',
        },
      ]}
      image={{ 
        src: '/images/testimonial-6.webp', 
        alt: 'HairTestimonial system in action',
        width: 1024,
        height: 1024 
      }}
    />
  </div>

  <Pricing
    title={`<span class="text-accent dark:text-white">One-Time Investment. Lifetime Growth.</span>`}
    prices={[lifetimeDeal]}
  />

  <FAQs
    class="-mt-16 px-6"
    title="Frequently Asked Questions"
    items={[
        { title: 'How is this different from a QR code I make myself?', description: 'A standard QR code just opens a link. Our engine includes a reputation filter to catch unhappy clients privately, a website widget to display reviews, and a 3-click flow optimized for busy clients.', icon: 'tabler:help' },
        { title: 'Do I need to give you my Google login?', description: 'No. We use your public Google Business link to sync everything. Your account stays 100% secure.', icon: 'tabler:lock' },
        { title: 'What if I have multiple locations?', description: 'Each location requires its own setup and QR engine. Contact us for "Multi-Chair" or "Multi-Location" discounts!', icon: 'tabler:building-store' },
        { title: 'Is it really a one-time payment?', description: 'Yes. Most competitors charge $50-$150 every single month. We charge a one-time setup fee for our labor and software logic. You own it for life.', icon: 'tabler:currency-dollar' },
    ]}
  >
    <Fragment slot="bg"><div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div></Fragment>
  </FAQs>

<Steps2
    class="-mt-16"
    title="Ready to dominate your local market?"
    subtitle="Join the salons using Schedule Hair to grow their buzz on autopilot. 100% White-Glove Setup."
    items={[
      {
        title: 'Same-Day Delivery',
        description: 'Get your custom codes and widget instructions in less than 24 hours.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Zero Tech Skills Required',
        description: 'If you can print a piece of paper, you can use this system.',
        icon: 'tabler:tool',
      },
      {
        title: 'Save $600+ Per Year',
        description: 'Stop the "SaaS drain." Pay once and never worry about your reputation bill again.',
        icon: 'tabler:coin',
      },
    ]}
    callToAction={{ text: 'Get Started Now - $99', href: '/pricing/' }}
    image={{ src: '/images/testimonial-3.webp', alt: 'Schedule Hair Alt3', width: 600, height: 600 }}
  />
</Layout>
