---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Features3 from '~/components/widgets/Features3.astro';
import { lifetimeDeal } from '~/data/pricingData';
import Hero from '~/components/widgets/Hero.astro';

const metadata = { 
  title: 'Pricing | Secure Your Elite Address.Hair URL', 
  description: 'Professional salon vanity URLs with zero monthly fees. Transform your Google Business Profile and Social Bio into a luxury portfolio.' 
};
---
<Layout metadata={metadata}>
  <HeroText 
    tagline="The Professional Standard"
    title="A Stunning Home for Your Artistry. Live in Hours." 
    subtitle="More than just a link—it's your salon's digital flagship. Own a beautiful vanity URL (address.hair/yoursalon) that transforms your social bio into a high-end experience."
  />

  <div class="-mt-16">
    <Pricing prices={[lifetimeDeal]} />
  </div>

  <Features3
    title="Elevate Every Touchpoint"
    subtitle="We bridge the gap between your work behind the chair and your presence online."
    columns={3}
    items={[
      { 
        title: 'Social Bio Transformation', 
        description: 'Ditch generic link tools. Your URL provides a high-end experience that keeps clients focused on your services and booking link.', 
        icon: 'tabler:link' 
      },
      { 
        title: 'Google Business Authority', 
        description: 'Replace generic links on your Google Profile with a dedicated salon homepage that creates a massive authority signal to local clients.', 
        icon: 'tabler:brand-google' 
      },
      { 
        title: 'Live Portfolio Sync', 
        description: 'We pull your live Instagram feed directly onto your unique URL, ensuring your portfolio is always current without you lifting a finger.', 
        icon: 'tabler:brand-instagram' 
      },
      { title: 'Detailed Menu Styling', description: 'Present your service menu with boutique styling, detailing your color work and extensions beautifully.', icon: 'tabler:clipboard-list' },
      { title: 'One-Time License', description: 'No monthly SaaS Taxes. Pay once and own your professional identity for life. We handle the hosting and security.', icon: 'tabler:coin' },
      { title: 'White-Glove Delivery', description: 'From setup to feed syncing, we handle the technical heavy lifting with guaranteed same-day delivery.', icon: 'tabler:headset' },
    ]}
  />

  <FAQs
    class="-mt-16 px-6"
    title="Pricing & Setup Questions"
    items={[
        { title: 'How does same-day setup work?', description: 'Secure your license, fill out our brief content form, and if received by 2PM EST, your site goes live before the business day ends.', icon: 'tabler:bolt' },
        { title: 'Can I use a custom .com?', description: 'Yes! We can manage your own standalone domain (yoursalon.com) for just $15/year, handling all DNS and SSL setup for you.', icon: 'tabler:world' },
        { title: 'Is this a monthly fee?', description: 'No. Address.Hair is a one-time investment for setup and boutique design. You never pay a monthly fee again.', icon: 'tabler:coin' },
    ]}
  >
    <Fragment slot="bg"><div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div></Fragment>
  </FAQs>

  <Hero class="-mt-16">
    <Fragment slot="image">
      <img src="/images/testimonial-5.webp" alt="Stylist reviewing feedback" class="mx-auto rounded-md w-full shadow-lg" loading="lazy" />
    </Fragment>
  </Hero>
</Layout>
