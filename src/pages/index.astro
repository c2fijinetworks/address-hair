---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import { headerData } from '~/navigation';
import FAQs from '~/components/widgets/FAQs.astro';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = { 
  title: 'Address.Hair | Boutique Websites for Stylists', 
  description: 'Your Salon Deserves a Digital Masterpiece. High-end websites with automated Instagram sync and vanity URLs for elite professionals.' 
};
---
<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header {...headerData} isSticky />
  </Fragment>
  
  <Hero2
    tagline="Boutique Web Development for Salons"
    title='<span class="text-accent dark:text-white">Your Salon Deserves a Digital Masterpiece.</span>'
    subtitle="We build and deploy elegant, high-converting websites that sync with your social media portfolio in real-time. Stand out with a professional address while you focus on the chair."
    actions={[
      { variant: 'primary', text: "Claim Your Salon's Website", href: '/pricing/' }, 
      { text: 'View Live Demo', href: '/demo' }
    ]}
    image={{ src: '/images/testimonial-5.webp', alt: 'Salon Hero' }}
  />

  <Features
    class="-mt-16"
    id="features"
    title="Everything Your Salon Needs"
    subtitle="We have distilled the essential elements of a high-performance salon website into a single, beautiful package."
    items={[
        { 
          title: 'Aesthetic Boutique Design', 
          description: 'Our layouts are custom-crafted to mirror the luxury of your physical salon space. We prioritize high-resolution imagery and elegant typography that tells your brand story.', 
          icon: 'tabler:palette' 
        },
        { 
          title: 'Automated Social Feeds', 
          description: 'We sync your Instagram directly to your homepage gallery. Every time you post a fresh transformation, your website updates automatically. Zero manual effort.', 
          icon: 'tabler:brand-instagram' 
        },
        { 
          title: 'Essential Business Strategy', 
          description: 'We integrate your booking engine directly into a clear layout, including interactive maps and up-to-date hours optimized specifically for mobile users.', 
          icon: 'tabler:info-circle' 
        },
        { 
          title: 'Professional Technical Suite', 
          description: 'We handle the enterprise-grade tech. Hosted on lightning-fast global networks with SSL security and custom domain routing for total stability.', 
          icon: 'tabler:cloud-computing' 
        },
    ]}
  />

  <Content
    class="-mt-16"
    tagline="Always Fresh. Zero Maintenance."
    title="Your site stays as fresh as your latest client's blowout."
    items={[
        { title: 'Real-time Instagram Sync', description: 'Your portfolio updates automatically every time you post a new transformation.', icon: 'tabler:refresh' },
        { title: 'Automatic Content Refresh', description: 'No more outdated websites. Your latest work is always front and center.', icon: 'tabler:camera' },
        { title: 'SEO Authority Signal', description: 'Google prioritizes dedicated professional URLs over generic social links.', icon: 'tabler:trending-up' },
    ]}
    image={{ src: '/images/testimonial-2.webp', alt: 'Stylist working on a client' }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        <span class="text-accent dark:text-white">Instant Instagram Portfolio</span>
      </h3>
      <p>Your website shouldn't be a chore. We automatically sync your latest posts directly to your homepage so your site reflects your current skill level 24/7.</p>
    </Fragment>
    <Fragment slot="bg"><div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div></Fragment>
  </Content>

  <div id="process" class="scroll-mt-20">
    <Steps2
      title="The Path to a Better Presence"
      subtitle="Three simple steps to your new digital home."
      items={[
        { title: '01. Sign up with your brand', description: 'Secure your license and choose your vanity URL.', icon: 'tabler:number-1' },
        { title: '02. We Build & Sync', description: 'Our studio crafts your site and connects your social feeds for auto-updates.', icon: 'tabler:number-2' },
        { title: '03. Launch & Shine', description: 'Go live on address.hair/mysalon and start attracting high-value clients.', icon: 'tabler:number-3' },
      ]}
      image={{ src: '/images/testimonial-6.webp', alt: 'Address Hair process' }}
    />
  </div>

  <Pricing 
    title='<span class="text-accent dark:text-white">Ready to elevate your salon’s brand?</span>' 
    prices={[lifetimeDeal]} 
  />

  <FAQs
    class="-mt-16 px-6"
    title="Deep Dive: How Address.Hair Works"
    items={[
        { title: 'What is a Vanity URL?', description: 'A branded link like <strong>address.hair/yoursalon</strong>. It replaces messy links in your bio with a professional presence.', icon: 'tabler:link' },
        { title: 'Is it really "Same-Day"?', description: 'Yes. If you submit your details by 2 PM, our team builds and deploys your site before you close for the day.', icon: 'tabler:bolt' },
        { title: 'Is this a subscription?', description: 'No. Address.Hair is a one-time investment. We charge for setup and hosting once. You own it for life.', icon: 'tabler:coin' },
        { title: 'Do I need tech skills?', description: 'None. Your site stays fresh by syncing with your Instagram. If you can post a photo, you can maintain your site.', icon: 'tabler:tool' },
    ]}
  >
     <Fragment slot="bg"><div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div></Fragment>
  </FAQs>
</Layout>
